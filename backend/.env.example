# Copy this file to `backend/.env` and fill in values. The app loads `backend/.env` only — not this example file.
# Do not commit `.env` (it is gitignored).

# --- Person B (AI/NLP) ---
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# --- Person A (STT / Scribe) ---
ELEVENLABS_API_KEY=

# --- Tunables (optional) ---
CLAUDE_MODEL=claude-sonnet-4-5
TAVILY_CALL_CAP=5
TAVILY_CACHE_TTL_SEC=3600
FRONTEND_ORIGIN=http://localhost:8080
