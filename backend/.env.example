# Copy this file to `backend/.env` and fill in values. The app loads `backend/.env` only — not this example file.
# Do not commit `.env` (it is gitignored).

# --- Person B (AI/NLP) ---
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# --- Person A (STT / Scribe) ---
ELEVENLABS_API_KEY=
# Optional legacy alias (backend accepts either env name):
# ELEVEN_LABS_API_KEY=

# --- Tunables (optional) ---
CLAUDE_MODEL=claude-sonnet-4-5
TAVILY_CALL_CAP=5
TAVILY_CACHE_TTL_SEC=3600
FRONTEND_ORIGIN=http://localhost:8080
STT_PROVIDER=auto
# FINE_TUNED_STT_MODEL_PATH=/absolute/path/to/backend/stt/models/fine_tuned_telephony
FINE_TUNED_STT_LANGUAGE=english
FINE_TUNED_STT_TASK=transcribe
FINE_TUNED_STT_DEVICE=auto
FINE_TUNED_STT_DTYPE=auto
FINE_TUNED_STT_WORD_TIMESTAMPS=false

# If you see "ffmpeg was not found in PATH" while Uvicorn runs from the IDE, set full paths
# (ffprobe is auto-detected next to ffmpeg if FFPROBE_PATH is empty):
# FFMPEG_PATH=C:\Program Files\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\Program Files\ffmpeg\bin\ffprobe.exe
